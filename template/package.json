{
  "name": "phaser-project-template",
  "version": "4.0.0",
  "description": "Phaser 4.0.0 starter template with TypeScript and webpack.",
  "homepage": "https://github.com/yandeu/phaser-project-template#readme",
  "main": "index.js",
  "scripts": {
    "start": "webpack serve --open --config webpack/webpack.dev.js",
    "build": "rimraf public && webpack --config webpack/webpack.prod.js",
    "bundle": "npm run build",
    "serve": "serve public",
    "format": "prettier --check \"src/**/*.{ts,scss}\"",
    "format:write": "prettier --write \"src/**/*.{ts,scss}\""
  },
  "keywords": [
    "Phaser",
    "Phaser 4",
    "Phaser4",
    "html5 game",
    "TypeScript",
    "webpack",
    "starter"
  ],
  "author": {
    "name": "Yannick Deubel",
    "url": "https://github.com/yandeu"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yandeu/phaser-project-template.git"
  },
  "template": {
    "name": "phaser-project-template",
    "url": "https://github.com/yandeu/phaser-project-template",
    "author": "Yannick Deubel (https://github.com/yandeu)"
  },
  "engines": {
    "node": ">=12"
  },
  "license": "MIT",
  "devDependencies": {
    "@yandeu/prettier-config": "^0.0.4",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.2",
    "html-webpack-plugin": "^5.6.5",
    "javascript-obfuscator": "^4.2.1",
    "mime-types": "^3.0.2",
    "mini-css-extract-plugin": "^2.9.4",
    "path": "^0.12.7",
    "postcss": "^8.5.6",
    "postcss-loader": "^8.2.0",
    "prettier": "^3.7.4",
    "rimraf": "^6.1.2",
    "sass": "^1.94.2",
    "sass-loader": "^16.0.6",
    "serve": "^14.2.5",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "webpack": "^5.103.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.2.2",
    "webpack-merge": "^6.0.1",
    "webpack-obfuscator": "^3.5.1"
  },
  "dependencies": {
    "@types/webfontloader": "^1.6.38",
    "phaser": "^4.0.0",
    "webfontloader": "^1.6.28"
  }
}
